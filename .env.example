# ==============================================================================
# NexusMind Environment Configuration
# ==============================================================================
# Copy this file to .env.local and fill in all required values.
# NEVER commit .env.local — it is gitignored for security.
# Run: npx tsx scripts/check-env.ts to validate your configuration.
# ==============================================================================

# ------------------------------------------------------------------------------
# MemWal — Persistent Agent Memory
# ------------------------------------------------------------------------------
# Obtain these from the MemWal Playground (https://playground.memory.walrus.xyz)
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

# ------------------------------------------------------------------------------
# Walrus — Decentralized Blob Storage
# ------------------------------------------------------------------------------
WALRUS_NETWORK=testnet
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ------------------------------------------------------------------------------
# Sui — Blockchain Layer
# ------------------------------------------------------------------------------
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
AGENT_PRIVATE_KEY=

# ------------------------------------------------------------------------------
# Deployed Move Package
# ------------------------------------------------------------------------------
# Set these after running: npx tsx scripts/deploy-move.ts
MOVE_PACKAGE_ID=
AGENT_REGISTRY_ID=

# ------------------------------------------------------------------------------
# Seal — Threshold Encryption
# ------------------------------------------------------------------------------
SEAL_KEY_SERVER_URLS=https://key-server.testnet.sui.io

# ------------------------------------------------------------------------------
# Sui Stack Messaging — Agent-to-Agent Communication
# ------------------------------------------------------------------------------
MESSAGING_RELAYER_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# Public Variables (accessible in browser via NEXT_PUBLIC_ prefix)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_WALRUS_NETWORK=testnet
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_MOVE_PACKAGE_ID=
NEXT_PUBLIC_APP_URL=https://nexusmind.vercel.app
